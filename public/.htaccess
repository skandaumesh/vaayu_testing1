# SPA fallback for React Router — serve index.html for all non-file routes
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]

# SEO: serve the crawler-visible copy (event meta + JSON-LD baked in) for the
# REVIVE 2026 route; React mounts on top of it for real visitors
RewriteRule ^revive-2026/?$ /revive-2026.html [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Cache static assets aggressively (Vite fingerprints them)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>
